#!/usr/bin/env bash
#MISE description="Symlink rysk-tanaka/skills and restore external skills via gh skill install"
#MISE dir="{{config_root}}"
set -euo pipefail

# Initial clone only — `git pull` is intentionally not invoked. Users edit the
# skills repo directly there, so unattended pulls would risk disrupting
# in-progress work. Update manually with `git -C "${SKILLS_REPO_DIR}" pull`.
SKILLS_REPO_URL="${SKILLS_REPO_URL:-https://github.com/rysk-tanaka/skills.git}"
SKILLS_REPO_DIR="${SKILLS_REPO_DIR:-${HOME}/Repositories/rysk/skills}"
DOTFILES_PATH="${DOTFILES_PATH:-$(cd "$(dirname "$0")/../../.." && pwd)}"
TARGET_DIR="${DOTFILES_PATH}/.claude/skills"

# `git rev-parse` で git worktree (`.git` がファイル形式) も正しく扱う。
if [[ -e "${SKILLS_REPO_DIR}" ]] && ! git -C "${SKILLS_REPO_DIR}" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  echo "ERROR: ${SKILLS_REPO_DIR} exists but is not a git repository" >&2
  echo "       Remove it or convert to a clone of ${SKILLS_REPO_URL}" >&2
  exit 1
fi

if [[ ! -d "${SKILLS_REPO_DIR}" ]]; then
  echo "Cloning skills repo to ${SKILLS_REPO_DIR}..."
  mkdir -p "$(dirname "${SKILLS_REPO_DIR}")"
  git clone "${SKILLS_REPO_URL}" "${SKILLS_REPO_DIR}"
fi

# 相対パス上書き時に symlink target が `.claude/skills/` 基準で壊れないよう絶対パス化。
SKILLS_REPO_DIR="$(cd "${SKILLS_REPO_DIR}" && pwd -P)"

if [[ ! -d "${SKILLS_REPO_DIR}/skills" ]]; then
  echo "ERROR: ${SKILLS_REPO_DIR}/skills not found" >&2
  exit 1
fi

mkdir -p "${TARGET_DIR}"

# 子ディレクトリが無い場合の literal `*/` 展開で broken symlink を作らないため。
shopt -s nullglob

linked=0
for skill_dir in "${SKILLS_REPO_DIR}/skills"/*/; do
  skill_name="$(basename "${skill_dir}")"
  link_path="${TARGET_DIR}/${skill_name}"

  if [[ -e "${link_path}" && ! -L "${link_path}" ]]; then
    echo "WARN: ${link_path} exists as a real path, skipping" >&2
    continue
  fi

  ln -sfn "${skill_dir%/}" "${link_path}"
  linked=$((linked + 1))
done

# skills repo から削除された skill の broken symlink を除去 (`-L && ! -e` で検出)
removed=0
for link_path in "${TARGET_DIR}"/*; do
  if [[ -L "${link_path}" && ! -e "${link_path}" ]]; then
    echo "Removing stale symlink: $(basename "${link_path}")"
    unlink "${link_path}"
    removed=$((removed + 1))
  fi
done

echo "Linked ${linked} skill(s) into ${TARGET_DIR}/"
if (( removed > 0 )); then
  echo "Removed ${removed} stale symlink(s)"
fi

# 外部 skill (catalog.json の source) を復元。実体は gitignore されるため、初回
# clone 直後やマシン移行時にここで復元する。source が owner/repo 形式のものは
# gh skill install、gist:<id> 形式のものは gh api (gh skill install が gist 非対応
# のため) で取得する。rysk-tanaka/skills は上の symlink で扱うため除外。
# pin が在れば --pin で固定する。
CATALOG="${TARGET_DIR}/catalog.json"

if [[ ! -f "${CATALOG}" ]]; then
  echo "catalog.json not found, skipping external skill restore" >&2
elif ! command -v gh >/dev/null 2>&1 || ! command -v jq >/dev/null 2>&1; then
  echo "WARN: gh and jq are required to restore external skills, skipping" >&2
else
  installed=0
  skipped=0
  while IFS=$'\t' read -r name source pin; do
    [[ -z "${name}" ]] && continue

    # 既存 (SKILL.md が在る) skill は再 install しない (更新は手動 gh skill update に委ねる)。
    if [[ -f "${TARGET_DIR}/${name}/SKILL.md" ]]; then
      skipped=$((skipped + 1))
      continue
    fi

    pin_args=()
    [[ -n "${pin}" ]] && pin_args=(--pin "${pin}")

    echo "Installing external skill: ${name} (${source}${pin:+@${pin}})"
    # ${arr[@]+...} guards empty-array expansion under `set -u` on bash 3.2 (macOS).
    gh skill install "${source}" "${name}" ${pin_args[@]+"${pin_args[@]}"} \
      --agent claude-code --dir "${TARGET_DIR}" --force
    installed=$((installed + 1))
  done < <(jq -r '.[]
    | select(.source != null and (.source | test("/")) and .source != "rysk-tanaka/skills")
    | [.name, .source, (.pin // "")] | @tsv' "${CATALOG}")

  echo "External skills: ${installed} installed, ${skipped} already present"

  # gist 由来の skill (source が "gist:<id>" 形式) は gh skill install が gist を
  # 扱えないため gh api で復元する。gist はフラット構造なので全ファイルを書き出す。
  gist_installed=0
  gist_skipped=0
  while IFS=$'\t' read -r name gist_id; do
    [[ -z "${name}" || -z "${gist_id}" ]] && continue

    # 既存 (SKILL.md が在る) skill は再取得しない (更新は手動で gist を pull し直す)。
    if [[ -f "${TARGET_DIR}/${name}/SKILL.md" ]]; then
      gist_skipped=$((gist_skipped + 1))
      continue
    fi

    echo "Restoring gist skill: ${name} (gist:${gist_id})"
    # gist JSON は 1 回だけ取得し、ファイルごとの再取得 (N+1) を避ける。
    gist_json="$(gh api "gists/${gist_id}")"

    # 一時ディレクトリへ全ファイルを書き出してから本配置する。存在ゲートとなる
    # SKILL.md を最後に mv することで、他ファイルが揃う前にゲートが立つのを防ぎ、
    # 途中失敗時はゲートが立たず次回再復元される。
    # content 抽出は jq -j (改行を付与しない) で gist をそのままバイト再現する。
    staging="$(mktemp -d)"
    while IFS= read -r fname; do
      [[ -z "${fname}" ]] && continue
      jq -j --arg f "${fname}" '.files[$f].content' <<<"${gist_json}" \
        > "${staging}/${fname}"
    done < <(jq -r '.files | keys[]' <<<"${gist_json}")

    dest="${TARGET_DIR}/${name}"
    mkdir -p "${dest}"
    for f in "${staging}"/*; do
      [[ "$(basename "${f}")" == "SKILL.md" ]] && continue
      mv -f "${f}" "${dest}/"
    done
    mv -f "${staging}/SKILL.md" "${dest}/SKILL.md"
    rmdir "${staging}" 2>/dev/null || true
    gist_installed=$((gist_installed + 1))
  done < <(jq -r '.[]
    | select(.source != null and (.source | startswith("gist:")))
    | [.name, (.source | ltrimstr("gist:"))] | @tsv' "${CATALOG}")

  if (( gist_installed > 0 || gist_skipped > 0 )); then
    echo "Gist skills: ${gist_installed} restored, ${gist_skipped} already present"
  fi
fi
