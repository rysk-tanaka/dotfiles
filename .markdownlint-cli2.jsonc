{
  // Skip untracked artifacts and symlinks into other repos, which lint themselves
  "gitignore": true,
  "config": {
    "MD013": false,
    "MD024": false,
    "MD033": false,
    "MD162": false,
  },
  "ignores": [
    "**/node_modules/**",
    "**/target/**",
    "**/.venv/**",
    "**/venv/**",
    "**/.terraform/**",
    "**/build/**",
    "**/.playwright-mcp/**",
    ".codex/skills/**",
    ".tmp/**",
    "**/*.local.md",
  ],
}
